# python-service/.env.example
# Copia este archivo a .env y llena con tus credenciales de ACRCloud
#
# Obtén credenciales GRATIS en: https://www.acrcloud.com/
# - 1000 requests/mes gratis
# - Sin tarjeta de crédito
# - Funciona inmediatamente

# Host de ACRCloud (depende de tu región)
# Opciones comunes:
# - identify-us-west-2.acrcloud.com (USA West)
# - identify-us-east-1.acrcloud.com (USA East)
# - identify-eu-west-1.acrcloud.com (Europe)
# - identify-ap-southeast-1.acrcloud.com (Asia)
ACR_HOST=identify-us-west-2.acrcloud.com

# Tu Access Key de ACRCloud (lo encuentras en tu dashboard)
ACR_ACCESS_KEY=tu_access_key_aqui

# Tu Access Secret de ACRCloud
ACR_ACCESS_SECRET=tu_access_secret_aqui
