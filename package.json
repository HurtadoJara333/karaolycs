{
  "name": "karaoke-teleprompter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "dev:python": "cd python-service && python -m uvicorn main:app --reload --port 8000",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:python\""
  },
  "dependencies": {
    "next": "15.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "^5",
    "concurrently": "^9.0.0"
  }
}
